#include <Keypad.h>
#include <Wire.h>
#include <LiquidCrystal_I2C.h>

// ── Configuración del teclado 4×4 ──────────────────────────
const byte FILAS = 4;
const byte COLS  = 4;

char teclas[FILAS][COLS] = {
  {'1','2','3','A'},
  {'4','5','6','B'},
  {'7','8','9','C'},
  {'*','0','#','D'}
};

byte pinesFilas[FILAS] = {2, 3, 4, 5};
byte pinesCols[COLS]   = {6, 7, 8, 9};

Keypad teclado = Keypad(makeKeymap(teclas), pinesFilas, pinesCols, FILAS, COLS);

// ── Motores DC (aficionado) via L298N o L293D ──────────────
// Cada módulo tiene su propio pin de habilitación (ENA/ENB)
// Un solo sentido de giro es suficiente para expulsar
// Conecta: IN1 → 5V fijo, IN2 → GND fijo, ENA → pin PWM
// O más simple: pin HIGH = motor ON, LOW = motor OFF

const int MOTOR_PINES[8] = {10, 11, 12, 13, A1, A2, A3, A4};
// Estos pines van al pin ENA (enable) de cada canal del puente H
// Los pines 10, 11 son PWM; para velocidad variable úsalos primero.
// A1–A4 son digitales simples (ON/OFF sin PWM).

// Velocidad PWM para los pines que lo soportan (0–255)
const int VELOCIDAD_PWM = 200;

// ── LCD I2C ────────────────────────────────────────────────
LiquidCrystal_I2C lcd(0x27, 16, 2);

// ── Tabla de módulos ───────────────────────────────────────
struct Modulo {
  const char* codigo;
  const char* objeto;
};

Modulo modulos[8] = {
  {"11", "Objeto A"},
  {"22", "Objeto B"},
  {"33", "Objeto C"},
  {"44", "Objeto D"},
  {"55", "Objeto E"},
  {"66", "Objeto F"},
  {"77", "Objeto G"},
  {"88", "Objeto H"}
};

// ── Tiempo de activación del motor (ms) ───────────────────
const unsigned long TIEMPO_MOTOR = 7000;

// ── Variables de estado ────────────────────────────────────
String entradaActual = "";
const int MAX_DIGITOS = 2;

// ──────────────────────────────────────────────────────────
void setup() {
  Serial.begin(9600);

  for (int i = 0; i < 8; i++) {
    pinMode(MOTOR_PINES[i], OUTPUT);
    digitalWrite(MOTOR_PINES[i], LOW);  // motores apagados al inicio
  }

  lcd.init();
  lcd.backlight();
  mostrarBienvenida();
}

// ──────────────────────────────────────────────────────────
void loop() {
  char tecla = teclado.getKey();

  if (tecla) {
    if (tecla == '*') {
      entradaActual = "";
      mostrarEspera();

    } else if (tecla == '#') {
      procesarCodigo(entradaActual);
      entradaActual = "";

    } else if (isDigit(tecla) && entradaActual.length() < MAX_DIGITOS) {
      entradaActual += tecla;
      mostrarEntrada();

      if (entradaActual.length() == MAX_DIGITOS) {
        delay(300);
        procesarCodigo(entradaActual);
        entradaActual = "";
      }
    }
  }
}

// ── Valida código y despacha al módulo correcto ────────────
void procesarCodigo(String codigo) {
  if (codigo.length() == 0) return;

  for (int i = 0; i < 8; i++) {
    if (codigo == modulos[i].codigo) {
      activarModulo(i);
      return;
    }
  }

  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print("Codigo invalido");
  lcd.setCursor(0, 1);
  lcd.print("Intente de nuevo");
  delay(2000);
  mostrarEspera();
}

// ── Enciende el motor 7 s y luego lo apaga ─────────────────
void activarModulo(int idx) {
  // Mostrar módulo activo
  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print("Modulo ");
  lcd.print(idx + 1);
  lcd.print(" activo");
  lcd.setCursor(0, 1);
  lcd.print(modulos[idx].objeto);

  // Encender motor (PWM en pines compatibles, digital en el resto)
  int pin = MOTOR_PINES[idx];
  if (pin == 10 || pin == 11) {
    analogWrite(pin, VELOCIDAD_PWM);   // velocidad controlada por PWM
  } else {
    digitalWrite(pin, HIGH);           // encendido simple ON/OFF
  }

  // Cuenta regresiva en LCD durante los 7 segundos
  for (int seg = 7; seg >= 1; seg--) {
    lcd.setCursor(0, 1);
    lcd.print("Tiempo: ");
    lcd.print(seg);
    lcd.print("s  ");
    delay(1000);
  }

  // Apagar motor
  if (pin == 10 || pin == 11) {
    analogWrite(pin, 0);
  } else {
    digitalWrite(pin, LOW);
  }

  // Confirmación
  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print("Motor detenido");
  lcd.setCursor(0, 1);
  lcd.print(modulos[idx].objeto);
  delay(2000);

  mostrarEspera();
}

// ── Helpers de pantalla ────────────────────────────────────
void mostrarBienvenida() {
  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print("  Dispensador   ");
  lcd.setCursor(0, 1);
  lcd.print(" Ingrese codigo ");
  delay(2000);
  mostrarEspera();
}

void mostrarEspera() {
  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print("Codigo (2 dig.) ");
  lcd.setCursor(0, 1);
  lcd.print("> ");
}

void mostrarEntrada() {
  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print("Codigo: ");
  lcd.print(entradaActual);
  lcd.setCursor(0, 1);
  lcd.print("# confirmar");
}
